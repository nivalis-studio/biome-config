{
	"name": "@nivalis/biome-config",
	"version": "2.4.13",
	"description": "Configuration for biome",
	"main": "./biome.json",
	"license": "MIT",
	"homepage": "https://github.com/nivalis-studio/biome-config#readme",
	"repository": {
		"url": "git+https://github.com/nivalis-studio/biome-config.git"
	},
	"bugs": {
		"url": "https://github.com/nivalis-studio/biome-config/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"prepare": "lefthook install",
		"lint": "biome check",
		"lint:fix": "biome check --write",
		"insights:normalize": "node ./scripts/biome-insights/normalize.mjs",
		"insights:summary": "node ./scripts/biome-insights/summarize.mjs"
	},
	"files": [
		"biome.json"
	],
	"keywords": [
		"biome",
		"linter",
		"formatter",
		"fixer"
	],
	"packageManager": "pnpm@10.33.2",
	"peerDependencies": {
		"@biomejs/biome": ">=2"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@commitlint/cli": "catalog:",
		"@commitlint/config-conventional": "catalog:",
		"bumpp": "catalog:",
		"lefthook": "catalog:",
		"taze": "catalog:"
	}
}
